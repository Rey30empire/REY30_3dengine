# Copy these values into your deployment environment before deploy.
# For a local production-like boot on your machine, place them in .env.production.local
# and use `pnpm run start:production:local`.
# Server encryption secret for storing user BYOK credentials securely.
# Generate one with: pnpm run security:generate-secret
# Keep this stable. Do not set REY30_ENCRYPTION_KEY and APP_ENCRYPTION_KEY to different values.
REY30_ENCRYPTION_KEY=replace_with_base64_32_plus_bytes
# Optional alias if your hosting standard already uses APP_ENCRYPTION_KEY.
# APP_ENCRYPTION_KEY=replace_with_same_value_as_rey30_encryption_key
# Optional fallback if you prefer reusing NEXTAUTH secret as encryption source.
NEXTAUTH_SECRET=replace_with_strong_secret

# Auth / registration model
REY30_REGISTRATION_MODE=invite_only
REY30_REGISTRATION_INVITE_TOKEN=replace_with_invite_token
REY30_BOOTSTRAP_OWNER_TOKEN=replace_with_owner_bootstrap_token

# Runtime networking
REY30_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,https://127.0.0.1:8443,https://localhost:8443,https://your-domain.com
# Optional local semi-production HTTPS profile
# REY30_HTTPS_HOST=localhost
# REY30_HTTPS_PORT=8443

# Distributed rate limiting
# Required in production for auth and cost-heavy endpoints by default.
REY30_UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
REY30_UPSTASH_REDIS_REST_TOKEN=replace_with_upstash_token
# Optional single-node override. Keep disabled unless you intentionally run one app instance only.
# REY30_ALLOW_IN_MEMORY_RATE_LIMIT_PRODUCTION=false
# Optional auth-specific rate limits (defaults shown)
# REY30_RATE_LIMIT_AUTH_WINDOW_MS=600000
# REY30_RATE_LIMIT_LOGIN_MAX_REQUESTS=8
# REY30_RATE_LIMIT_REGISTER_MAX_REQUESTS=4

# Remote fetch allowlists (comma-separated hostnames)
REY30_REMOTE_FETCH_ALLOWLIST_OPENAI=api.openai.com
REY30_REMOTE_FETCH_ALLOWLIST_MESHY=api.meshy.ai
REY30_REMOTE_FETCH_ALLOWLIST_RUNWAY=api.dev.runwayml.com
REY30_REMOTE_FETCH_ALLOWLIST_ASSETS=cdn.your-domain.com

# Persistence
# Local dev SQLite example:
# DATABASE_URL=file:C:/apps/REY30_3dengine/prisma/prisma/dev.db
#
# Local production-like run on your machine:
# HOSTNAME=127.0.0.1
# PORT=3000
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/rey30?schema=public
#
# Recommended server SQL example (PostgreSQL):
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/rey30?schema=public
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/rey30?schema=public
# Netlify DB / Neon:
# Netlify can inject NETLIFY_DATABASE_URL automatically once the site is linked
# and @netlify/neon is installed. The runtime and Prisma helpers in this repo
# now map NETLIFY_DATABASE_URL -> DATABASE_URL automatically when needed.
# NETLIFY_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/rey30?sslmode=require
# Shared provider credentials (optional if you want collaborators to enter only one shared token)
# OPENAI_API_KEY=sk-...
# MESHY_API_KEY=msy_...
# Preferred bootstrap/fallback key for the invite/shared profile OpenAI credential.
# For persistent rotation in DB:
#   $env:INVITE_PROFILE_OPENAI_API_KEY="sk-proj-tu-clave-nueva"
#   npx tsx scripts/rotate-invite-openai-key.ts
# INVITE_PROFILE_OPENAI_API_KEY=sk-...
# REY30_SHARED_ACCESS_TOKEN=replace_with_shared_access_token
# REY30_SHARED_ACCESS_EMAIL=shared-access@rey30.local
# REY30_SHARED_ACCESS_NAME=REY30 Shared Access
# REY30_SHARED_ACCESS_ROLE=OWNER
# Script Workspace can auto-switch to Netlify Blobs on Netlify runtimes.
# REY30_SCRIPT_STORAGE_BACKEND=netlify-blobs
# REY30_SCRIPT_BLOB_STORE=rey30-scripts
# Gallery can also auto-switch to Netlify Blobs on Netlify runtimes.
# REY30_GALLERY_STORAGE_BACKEND=netlify-blobs
# REY30_GALLERY_BLOB_STORE=rey30-gallery
# Modular Character Lab can also auto-switch to Netlify Blobs on Netlify runtimes.
# REY30_MODULAR_CHARACTER_STORAGE_BACKEND=netlify-blobs
# REY30_MODULAR_CHARACTER_BLOB_STORE=rey30-modular-characters
# Optional local fallback root when using filesystem mode:
# REY30_MODULAR_CHARACTER_ROOT=/var/data/rey30/modular-characters
# Upload limits for source bundles:
# REY30_MODULAR_MAX_SOURCE_FILE_MB=80
# REY30_MODULAR_MAX_SOURCE_BUNDLE_MB=250
#
# Optional when DATABASE_URL points to external SQL instead of a local file:
# provide the path to a dump artifact so ops backups can include database state.
# Example: REY30_DATABASE_BACKUP_PATH=C:/backups/rey30/latest.dump
# REY30_DATABASE_BACKUP_PATH=
#
# Render persistent disk example:
# REY30_TRUST_PROXY=true
# REY30_ASSET_ROOT=/var/data/rey30/assets
# REY30_GALLERY_ROOT=/var/data/rey30/gallery
# REY30_INPUT_GALLERY_ROOT=/var/data/rey30/input-gallery
# REY30_PACKAGE_ROOT=/var/data/rey30/packages
# REY30_EXPORT_ROOT=/var/data/rey30/exports
# REY30_SCRIPT_ROOT=/var/data/rey30/scripts
# REY30_SOURCE_PROJECT_DIR=/var/data/rey30/source
# REY30_BACKUP_ROOT=/var/data/rey30/backups

# Keep disabled unless explicitly needed
REY30_ENABLE_TERMINAL_API=false
REY30_ENABLE_TERMINAL_API_REMOTE=false
